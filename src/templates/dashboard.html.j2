<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Simon Cai's Personalised Research Feed</title>
<style>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --text: #1a1a1a;
    --muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --tier-high-bg: #fee2e2;
    --tier-high-fg: #991b1b;
    --tier-medium-bg: #fef3c7;
    --tier-medium-fg: #92400e;
    --tier-low-bg: #e0e7ff;
    --tier-low-fg: #3730a3;
    --chip-bg: #f3f4f6;
    --chip-fg: #374151;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0f172a;
      --surface: #1e293b;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --border: #334155;
      --accent: #60a5fa;
      --tier-high-bg: #7f1d1d;
      --tier-high-fg: #fecaca;
      --tier-medium-bg: #78350f;
      --tier-medium-fg: #fde68a;
      --tier-low-bg: #312e81;
      --tier-low-fg: #c7d2fe;
      --chip-bg: #334155;
      --chip-fg: #cbd5e1;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
  }
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 1rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .container { max-width: 960px; margin: 0 auto; }
  h1 { margin: 0 0 0.25rem; font-size: 1.5rem; }
  .tagline {
    margin: 0.35rem 0 0.5rem;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--text);
    max-width: 780px;
  }
  .tagline strong { color: var(--accent); }
  .meta { color: var(--muted); font-size: 0.875rem; }
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    align-items: center;
  }
  .tier-btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.15s;
  }
  .tier-btn:hover { border-color: var(--accent); }
  .tier-btn.active {
    background: var(--accent);
    color: #ffffff;
    border-color: var(--accent);
  }
  #search {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
  }
  #search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  main { padding: 1.5rem 1rem; }
  .paper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
    transition: opacity 0.15s;
  }
  .paper.read { opacity: 0.55; }
  .paper.read .paper-title a { text-decoration: line-through; color: var(--muted); }
  .paper-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .paper-title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.35;
    flex: 1;
  }
  .paper-title a { color: var(--text); text-decoration: none; }
  .paper-title a:hover { color: var(--accent); text-decoration: underline; }
  .paper-actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.5rem;
  }
  .read-toggle {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    border-radius: 0.375rem;
    padding: 0.2rem 0.55rem;
    font-size: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .read-toggle:hover { color: var(--accent); border-color: var(--accent); }
  .paper.read .read-toggle { color: var(--accent); border-color: var(--accent); }
  .tier-badge {
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .tier-badge.high { background: var(--tier-high-bg); color: var(--tier-high-fg); }
  .tier-badge.medium { background: var(--tier-medium-bg); color: var(--tier-medium-fg); }
  .tier-badge.low { background: var(--tier-low-bg); color: var(--tier-low-fg); }
  .hide-read-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
  }
  .hide-read-wrap input { cursor: pointer; }
  .paper-meta {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0.25rem 0 0.5rem;
  }
  .paper-meta .journal { font-style: italic; }
  .paper-meta .dot { margin: 0 0.4rem; }
  .paper-abstract {
    margin: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text);
    max-height: 4.5em;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  .paper-abstract.expanded { max-height: none; }
  .paper-abstract:not(.expanded)::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5em;
    background: linear-gradient(transparent, var(--surface));
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }
  .chip {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    background: var(--chip-bg);
    color: var(--chip-fg);
    border-radius: 9999px;
  }
  .score-detail {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }
  .llm-reason {
    font-size: 0.85rem;
    font-style: italic;
    color: var(--muted);
    margin: 0.5rem 0;
    padding: 0.5rem 0.75rem;
    border-left: 3px solid var(--accent);
    background: var(--chip-bg);
    border-radius: 0 0.25rem 0.25rem 0;
  }
  #empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--muted);
  }
  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    font-size: 0.8rem;
  }
</style>
</head>
<body>
<header>
  <div class="container">
    <h1>Simon Cai's Personalised Research Feed</h1>
    <p class="tagline">
      Weekly feed of new papers from Nature, Cell family, and bioRxiv, scored against
      <strong>my</strong> Paperpile reading history (recency-weighted) and re-ranked by Claude with context from
      <strong>my</strong> personal research knowledgebase. Rankings reflect my work in cancer proteomics,
      foundation models, and multi-omics integration &mdash; so &ldquo;must-read&rdquo; here won&rsquo;t match yours.
      Fork the <a href="https://github.com/ZhaoxiangSimonCai/SimonResearchRSS" target="_blank" rel="noopener">repo</a>
      to build your own.
    </p>
    <div class="meta" id="meta-line">
      Updated {{ updated_human }} &middot;
      <span id="meta-counts">{{ count }} papers</span>
      &middot; scored against {{ library_size }} library papers
    </div>
    <div class="controls">
      <button class="tier-btn active" data-tier="all">All</button>
      <button class="tier-btn" data-tier="high">Must-read</button>
      <button class="tier-btn" data-tier="medium">Worth scanning</button>
      <button class="tier-btn" data-tier="low">On the radar</button>
      <label class="hide-read-wrap">
        <input type="checkbox" id="hide-read"> Hide read
      </label>
      <input id="search" type="search" placeholder="Search title, abstract, authors, journal...">
    </div>
  </div>
</header>
<main>
  <div class="container" id="paper-list"></div>
  <div class="container" id="empty" style="display:none;">No papers match your filter.</div>
</main>
<footer>
  <div class="container">
    Auto-generated from {{ feeds|length }} feeds &middot;
    <a href="papers.json">raw JSON</a>
  </div>
</footer>

<script type="application/json" id="papers-data">{{ papers_json|safe }}</script>
<script>
(function () {
  const raw = document.getElementById('papers-data').textContent;
  const papers = JSON.parse(raw);
  const list = document.getElementById('paper-list');
  const empty = document.getElementById('empty');
  const search = document.getElementById('search');
  const hideReadCheckbox = document.getElementById('hide-read');
  const metaCounts = document.getElementById('meta-counts');
  let activeTier = 'all';
  let searchTerm = '';

  // ---------- read-state (localStorage) ----------
  const READ_KEY = 'srrss.readPapers';
  const HIDE_READ_KEY = 'srrss.hideRead';

  function getReadSet() {
    try {
      const stored = localStorage.getItem(READ_KEY);
      return new Set(stored ? JSON.parse(stored) : []);
    } catch (e) {
      return new Set();
    }
  }
  function saveReadSet(set) {
    try { localStorage.setItem(READ_KEY, JSON.stringify(Array.from(set))); }
    catch (e) { /* quota or disabled */ }
  }
  function isRead(id) { return readSet.has(id); }
  function toggleRead(id) {
    if (readSet.has(id)) readSet.delete(id);
    else readSet.add(id);
    saveReadSet(readSet);
  }
  // Garbage-collect localStorage entries whose IDs aren't in the current feed.
  function gcReadSet(currentIds) {
    const next = new Set();
    readSet.forEach(function (id) { if (currentIds.has(id)) next.add(id); });
    if (next.size !== readSet.size) {
      readSet = next;
      saveReadSet(readSet);
    }
  }
  let readSet = getReadSet();
  const allIds = new Set(papers.map(function (p) { return p.id; }));
  gcReadSet(allIds);

  // restore hide-read preference
  const savedHideRead = localStorage.getItem(HIDE_READ_KEY) === 'true';
  hideReadCheckbox.checked = savedHideRead;
  let hideRead = savedHideRead;

  // ---------- helpers ----------
  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }
  function formatAuthors(authors) {
    if (!authors || !authors.length) return '';
    if (authors.length <= 3) return authors.join(', ');
    return authors.slice(0, 3).join(', ') + ' et al.';
  }

  // ---------- counts shown in header + tier buttons ----------
  function recomputeCounts() {
    const total = papers.length;
    const unreadTotal = papers.filter(function (p) { return !isRead(p.id); }).length;
    const tierTotals = { high: 0, medium: 0, low: 0 };
    const tierUnread = { high: 0, medium: 0, low: 0 };
    papers.forEach(function (p) {
      if (tierTotals[p.tier] !== undefined) {
        tierTotals[p.tier] += 1;
        if (!isRead(p.id)) tierUnread[p.tier] += 1;
      }
    });
    metaCounts.textContent = total + ' papers (' + unreadTotal + ' unread)';
    document.querySelectorAll('.tier-btn').forEach(function (btn) {
      const t = btn.dataset.tier;
      const label = t === 'all' ? 'All'
        : t === 'high' ? 'Must-read'
        : t === 'medium' ? 'Worth scanning'
        : 'On the radar';
      const u = t === 'all' ? unreadTotal : tierUnread[t];
      const a = t === 'all' ? total : tierTotals[t];
      btn.textContent = label + ' (' + u + ' / ' + a + ')';
    });
  }

  // ---------- render ----------
  function render() {
    const term = searchTerm.toLowerCase();
    const filtered = papers.filter(function (p) {
      if (activeTier !== 'all' && p.tier !== activeTier) return false;
      if (hideRead && isRead(p.id)) return false;
      if (!term) return true;
      const hay = (
        (p.title || '') + ' ' +
        (p.abstract || '') + ' ' +
        (p.journal || '') + ' ' +
        (p.authors || []).join(' ')
      ).toLowerCase();
      return hay.indexOf(term) !== -1;
    });

    if (!filtered.length) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';

    const html = filtered.map(function (p) {
      const chips = (p.matched_keywords || [])
        .map(function (k) { return '<span class="chip">' + escapeHtml(k) + '</span>'; })
        .join('');
      const authorLine = formatAuthors(p.authors);
      const journalLine = escapeHtml(p.journal || '');
      const publishedLine = p.published ? new Date(p.published).toLocaleDateString() : '';
      const idAttr = escapeHtml(p.id);
      const readClass = isRead(p.id) ? ' read' : '';
      const readLabel = isRead(p.id) ? '✓ Read' : '↺ Mark read';
      const topYear = p.top_match_added_year ? ' &middot; top match added ' + p.top_match_added_year : '';
      const cosLine = (typeof p.max_cosine_weighted === 'number')
        ? ' &middot; weighted cosine ' + p.max_cosine_weighted.toFixed(3)
        : '';
      const llmLine = (typeof p.llm_score === 'number')
        ? ' &middot; LLM ' + p.llm_score.toFixed(0) + ' (stage1 ' + (p.stage1_score != null ? p.stage1_score.toFixed(0) : '?') + ')'
        : '';
      const sourceWeightLine = (typeof p.source_weight === 'number' && p.source_weight < 1.0 && typeof p.raw_final_score === 'number')
        ? ' &middot; source×' + p.source_weight.toFixed(2) + ' (raw ' + p.raw_final_score.toFixed(0) + ')'
        : '';
      const llmReasonHtml = p.llm_reason
        ? '<div class="llm-reason">' + escapeHtml(p.llm_reason) + '</div>'
        : '';
      return ''
        + '<article class="paper' + readClass + '" data-id="' + idAttr + '">'
        +   '<div class="paper-head">'
        +     '<h2 class="paper-title"><a href="' + escapeHtml(p.url) + '" target="_blank" rel="noopener">' + escapeHtml(p.title) + '</a></h2>'
        +     '<div class="paper-actions">'
        +       '<button class="read-toggle" data-action="toggle-read">' + readLabel + '</button>'
        +       '<span class="tier-badge ' + p.tier + '">' + p.final_score.toFixed(0) + '</span>'
        +     '</div>'
        +   '</div>'
        +   '<div class="paper-meta">'
        +     (authorLine ? '<span>' + escapeHtml(authorLine) + '</span>' : '')
        +     (authorLine && journalLine ? '<span class="dot">&middot;</span>' : '')
        +     (journalLine ? '<span class="journal">' + journalLine + '</span>' : '')
        +     (publishedLine ? '<span class="dot">&middot;</span><span>' + publishedLine + '</span>' : '')
        +   '</div>'
        +   llmReasonHtml
        +   (p.abstract ? '<div class="paper-abstract">' + escapeHtml(p.abstract) + '</div>' : '')
        +   (chips ? '<div class="chips">' + chips + '</div>' : '')
        +   '<div class="score-detail">embedding ' + p.embedding_score.toFixed(0) + ' &middot; keywords ' + p.keyword_score.toFixed(0) + cosLine + llmLine + sourceWeightLine + topYear + '</div>'
        + '</article>';
    }).join('');
    list.innerHTML = html;

    // enable abstract expand on click
    list.querySelectorAll('.paper-abstract').forEach(function (el) {
      el.addEventListener('click', function () { el.classList.toggle('expanded'); });
    });

    // wire read-toggle buttons
    list.querySelectorAll('[data-action="toggle-read"]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        const card = btn.closest('.paper');
        const id = card.getAttribute('data-id');
        toggleRead(id);
        const nowRead = isRead(id);
        card.classList.toggle('read', nowRead);
        btn.textContent = nowRead ? '✓ Read' : '↺ Mark read';
        recomputeCounts();
        if (hideRead && nowRead) {
          // remove from view immediately
          card.style.display = 'none';
        }
      });
    });
  }

  document.querySelectorAll('.tier-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.tier-btn').forEach(function (b) { b.classList.remove('active'); });
      btn.classList.add('active');
      activeTier = btn.dataset.tier;
      render();
    });
  });

  hideReadCheckbox.addEventListener('change', function (e) {
    hideRead = e.target.checked;
    localStorage.setItem(HIDE_READ_KEY, hideRead ? 'true' : 'false');
    render();
  });

  let searchTimer = null;
  search.addEventListener('input', function (e) {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function () {
      searchTerm = e.target.value;
      render();
    }, 120);
  });

  recomputeCounts();
  render();
})();
</script>
</body>
</html>
