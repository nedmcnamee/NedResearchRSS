<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ned's Personalised Research Feed</title>
<script>
  // Apply stored theme BEFORE CSS paints, so manual light/dark override
  // doesn't flash the wrong colour on first render. Runs synchronously
  // during head parsing.
  (function () {
    try {
      var t = localStorage.getItem('srrss.theme');
      if (t === 'dark' || t === 'light') {
        document.documentElement.setAttribute('data-theme', t);
      }
    } catch (e) { /* private mode / disabled storage */ }
  })();
</script>
<style>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --text: #1a1a1a;
    --muted: #6b7280;
    --border: #e5e7eb;
    --accent: #2563eb;
    --tier-high-bg: #fee2e2;
    --tier-high-fg: #991b1b;
    --tier-medium-bg: #fef3c7;
    --tier-medium-fg: #92400e;
    --tier-low-bg: #e0e7ff;
    --tier-low-fg: #3730a3;
    --chip-bg: #f3f4f6;
    --chip-fg: #374151;
    /* source-type colours (peer-reviewed, biology preprint, ML preprint) */
    --src-journal:  #2563eb;   /* blue — trusted peer-reviewed */
    --src-biorxiv:  #16a34a;   /* green — biology preprints */
    --src-arxiv:    #d97706;   /* amber — ML/CS firehose */
  }
  /* Auto dark mode — applies only when the user hasn't manually forced light. */
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) {
      --bg: #0f172a;
      --surface: #1e293b;
      --text: #f1f5f9;
      --muted: #94a3b8;
      --border: #334155;
      --accent: #60a5fa;
      --tier-high-bg: #7f1d1d;
      --tier-high-fg: #fecaca;
      --tier-medium-bg: #78350f;
      --tier-medium-fg: #fde68a;
      --tier-low-bg: #312e81;
      --tier-low-fg: #c7d2fe;
      --chip-bg: #334155;
      --chip-fg: #cbd5e1;
      --src-journal:  #60a5fa;
      --src-biorxiv:  #4ade80;
      --src-arxiv:    #fbbf24;
    }
  }
  /* Manual dark mode (user clicked the toggle) — wins regardless of OS setting. */
  :root[data-theme="dark"] {
    --bg: #0f172a;
    --surface: #1e293b;
    --text: #f1f5f9;
    --muted: #94a3b8;
    --border: #334155;
    --accent: #60a5fa;
    --tier-high-bg: #7f1d1d;
    --tier-high-fg: #fecaca;
    --tier-medium-bg: #78350f;
    --tier-medium-fg: #fde68a;
    --tier-low-bg: #312e81;
    --tier-low-fg: #c7d2fe;
    --chip-bg: #334155;
    --chip-fg: #cbd5e1;
    --src-journal:  #60a5fa;
    --src-biorxiv:  #4ade80;
    --src-arxiv:    #fbbf24;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
  }
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1.5rem 1rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .container { max-width: 960px; margin: 0 auto; }
  .title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }
  h1 { margin: 0 0 0.25rem; font-size: 1.5rem; flex: 1; }
  .theme-toggle {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
  }
  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .theme-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .tagline-details {
    margin: 0.35rem 0 0.5rem;
  }
  .tagline-details summary {
    cursor: pointer;
    font-size: 0.85rem;
    color: var(--muted);
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.15rem 0;
    user-select: none;
  }
  .tagline-details summary::-webkit-details-marker { display: none; }
  .tagline-details summary::before {
    content: "▸";
    display: inline-block;
    font-size: 0.75em;
    transition: transform 0.15s ease;
  }
  .tagline-details[open] summary::before { transform: rotate(90deg); }
  .tagline-details summary:hover { color: var(--accent); }
  .tagline {
    margin: 0.4rem 0 0;
    font-size: 0.9rem;
    line-height: 1.45;
    color: var(--text);
    max-width: 780px;
  }
  .tagline strong { color: var(--accent); }
  /* Desktop: skip the toggle entirely — JS sets `open` and CSS hides summary,
     so the description renders inline like a normal paragraph. */
  @media (min-width: 700px) {
    .tagline-details summary { display: none; }
    .tagline { margin-top: 0; }
  }
  /* Mobile: hide the button row, show the compact dropdown, tighten
     the sticky header so the controls don't dominate. */
  @media (max-width: 699px) {
    header { padding: 1rem 0.875rem; }
    header h1 { font-size: 1.25rem; }
    header .controls { gap: 0.5rem; margin-top: 0.65rem; }
    header .controls .tier-row { display: none; }
    header .controls .tier-select { display: inline-block; }
    header .controls #search {
      font-size: 0.85rem;
      min-width: 0;
      padding: 0.4rem 0.6rem;
    }
    header .controls .hide-read-wrap { font-size: 0.8rem; }
  }
  .meta { color: var(--muted); font-size: 0.875rem; }
  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
    align-items: center;
  }
  .tier-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .tier-btn {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .tier-btn:hover { border-color: var(--accent); }
  .tier-btn.active {
    background: var(--accent);
    color: #ffffff;
    border-color: var(--accent);
  }
  /* Mobile-only tier filter: native select replaces the button row. */
  .tier-select {
    display: none;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 0.375rem;
    font-size: 0.85rem;
    cursor: pointer;
    max-width: 100%;
  }
  .tier-select:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  #search {
    flex: 1;
    min-width: 200px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 0.375rem;
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
  }
  #search:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  main { padding: 1.5rem 1rem; }
  .paper {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--border);
    border-radius: 0.5rem;
    padding: 1.25rem;
    margin-bottom: 1rem;
    transition: opacity 0.15s;
  }
  .paper.source-journal { border-left-color: var(--src-journal); }
  .paper.source-biorxiv { border-left-color: var(--src-biorxiv); }
  .paper.source-arxiv   { border-left-color: var(--src-arxiv); }
  .paper.read { opacity: 0.55; }
  .paper.read .paper-title a { text-decoration: line-through; color: var(--muted); }
  .source-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.1rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.72rem;
    font-weight: 600;
    font-style: normal;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .source-pill.source-journal { color: var(--src-journal); border-color: var(--src-journal); }
  .source-pill.source-biorxiv { color: var(--src-biorxiv); border-color: var(--src-biorxiv); }
  .source-pill.source-arxiv   { color: var(--src-arxiv);   border-color: var(--src-arxiv); }
  .source-pill .src-icon { font-size: 0.9em; line-height: 1; }
  .paper-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }
  .paper-title {
    margin: 0;
    font-size: 1.1rem;
    line-height: 1.35;
    flex: 1;
  }
  .paper-title a { color: var(--text); text-decoration: none; }
  .paper-title a:hover { color: var(--accent); text-decoration: underline; }
  .paper-actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: 0.5rem;
  }
  .read-toggle {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    border-radius: 0.375rem;
    padding: 0.2rem 0.55rem;
    font-size: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .read-toggle:hover { color: var(--accent); border-color: var(--accent); }
  .paper.read .read-toggle { color: var(--accent); border-color: var(--accent); }
  .tier-badge {
    flex-shrink: 0;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .tier-badge.high { background: var(--tier-high-bg); color: var(--tier-high-fg); }
  .tier-badge.medium { background: var(--tier-medium-bg); color: var(--tier-medium-fg); }
  .tier-badge.low { background: var(--tier-low-bg); color: var(--tier-low-fg); }
  .hide-read-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
  }
  .hide-read-wrap input { cursor: pointer; }
  .paper-meta {
    color: var(--muted);
    font-size: 0.85rem;
    margin: 0.25rem 0 0.5rem;
  }
  .paper-meta .journal { font-style: italic; }
  .paper-meta .dot { margin: 0 0.4rem; }
  .paper-abstract {
    margin: 0.5rem 0;
    font-size: 0.9rem;
    color: var(--text);
    max-height: 4.5em;
    overflow: hidden;
    position: relative;
    cursor: pointer;
  }
  .paper-abstract.expanded { max-height: none; }
  .paper-abstract:not(.expanded)::after {
    content: "";
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1.5em;
    background: linear-gradient(transparent, var(--surface));
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 0.5rem;
  }
  .chip {
    font-size: 0.7rem;
    padding: 0.15rem 0.55rem;
    background: var(--chip-bg);
    color: var(--chip-fg);
    border-radius: 9999px;
  }
  .chip.matched {
    background: var(--accent);
    color: #fff;
    font-weight: 600;
  }
  .score-detail {
    font-size: 0.75rem;
    color: var(--muted);
    margin-top: 0.5rem;
  }
  #empty {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--muted);
  }
  /* ---------- admin mode ---------- */
  .admin-only { display: none !important; }
  .admin-mode .admin-only { display: inline-flex !important; }
  .admin-btn {
    flex-shrink: 0;
    width: 2rem; height: 2rem; padding: 0;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    border-radius: 9999px;
    cursor: pointer;
    font-size: 0.85rem;
    display: inline-flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }
  .admin-btn:hover { color: var(--accent); border-color: var(--accent); }
  .admin-mode .admin-btn { color: var(--accent); border-color: var(--accent); }
  .star-rating {
    gap: 0.1rem; align-items: center; font-size: 0.85rem;
  }
  .star-rating .star {
    background: none; border: none; padding: 0; cursor: pointer;
    color: var(--muted); font-size: 1rem; line-height: 1; transition: color 0.1s;
  }
  .star-rating .star.active { color: #f59e0b; }
  .star-rating .star:hover { color: #fbbf24; }
  .sync-btn {
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 0.375rem;
    font-size: 0.8rem;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.15s;
  }
  .sync-btn:hover { border-color: var(--accent); color: var(--accent); }
  .add-paper-wrap {
    gap: 0.4rem; align-items: center; flex-basis: 100%;
  }
  .add-paper-input {
    flex: 1; min-width: 0;
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 0.375rem;
    font-size: 0.8rem;
  }
  .add-paper-input::placeholder { color: var(--muted); }
  .add-paper-input:focus { outline: 2px solid var(--accent); outline-offset: -1px; }
  .add-paper-btn {
    padding: 0.35rem 0.6rem;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: #fff;
    border-radius: 0.375rem;
    font-size: 0.8rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .add-paper-btn:disabled { opacity: 0.5; cursor: default; }
  .toast {
    position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
    padding: 0.65rem 1.25rem; border-radius: 0.5rem;
    background: var(--text); color: var(--bg);
    font-size: 0.85rem; z-index: 999; opacity: 0;
    transition: opacity 0.25s;
    pointer-events: none;
  }
  .toast.show { opacity: 1; }
  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--muted);
    font-size: 0.8rem;
  }
</style>
</head>
<body>
<header>
  <div class="container">
    <div class="title-row">
      <h1>Simon Cai's Personalised Research Feed</h1>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle light/dark theme" title="Toggle light/dark theme">☾</button>
      <button class="admin-btn" id="admin-toggle" type="button" aria-label="Admin mode" title="Admin mode">🔑</button>
    </div>
    <details class="tagline-details">
      <summary>About this feed</summary>
      <p class="tagline">
        Weekly feed of new papers from Nature, Cell family, bioRxiv, and arXiv, scored against
        <strong>my</strong> interests and keywords (recency-weighted), and re-ranked by AI with context from
        <strong>my</strong> personal research knowledgebase. Rankings reflect my work in cancer proteomics,
        foundation models, and multi-omics integration &mdash; so &ldquo;must-read&rdquo; here won&rsquo;t match yours.
        Fork the <a href="https://github.com/ZhaoxiangSimonCai/SimonResearchRSS" target="_blank" rel="noopener">repo</a>
        to build your own. Original credit to Simon Cai.
      </p>
    </details>
    <script>
      // Default the description to expanded on desktop, collapsed on mobile.
      // Re-syncs when crossing the breakpoint so a desktop→mobile resize
      // doesn't leave a long paragraph stuck open in the sticky header.
      (function () {
        var d = document.querySelector('.tagline-details');
        if (!d) return;
        var mq = window.matchMedia('(min-width: 700px)');
        function sync(e) {
          if (e.matches) d.setAttribute('open', '');
          else d.removeAttribute('open');
        }
        sync(mq);
        if (mq.addEventListener) mq.addEventListener('change', sync);
      })();
    </script>
    <div class="meta" id="meta-line">
      Updated {{ updated_human }} &middot;
      <span id="meta-counts">{{ count }} papers</span>
      &middot; scored against {{ library_size }} library papers
    </div>
    <div class="controls">
      <div class="tier-row">
        <button class="tier-btn active" data-tier="all">All</button>
        <button class="tier-btn" data-tier="high">Must-read</button>
        <button class="tier-btn" data-tier="medium">Worth scanning</button>
        <button class="tier-btn" data-tier="low">On the radar</button>
      </div>
      <select class="tier-select" id="tier-select" aria-label="Filter by tier">
        <option value="all" selected>All</option>
        <option value="high">Must-read</option>
        <option value="medium">Worth scanning</option>
        <option value="low">On the radar</option>
      </select>
      <label class="hide-read-wrap">
        <input type="checkbox" id="hide-read"> Hide read
      </label>
      <input id="search" type="search" placeholder="Search title, abstract, authors, journal...">
      <button class="sync-btn admin-only" id="sync-btn" type="button" title="Sync ratings &amp; queue to GitHub">🔄 Sync</button>
      <div class="add-paper-wrap admin-only">
        <input class="add-paper-input" id="add-paper-input" type="text" placeholder="Add paper by DOI or arXiv ID...">
        <button class="add-paper-btn" id="add-paper-btn" type="button">Add</button>
      </div>
    </div>
  </div>
</header>
<div class="toast" id="toast"></div>
<main>
  <div class="container" id="paper-list"></div>
  <div class="container" id="empty" style="display:none;">No papers match your filter.</div>
</main>
<footer>
  <div class="container">
    Auto-generated from {{ feeds|length }} feeds &middot;
    <a href="papers.json">raw JSON</a>
  </div>
</footer>

<script type="application/json" id="papers-data">{{ papers_json|safe }}</script>
<script type="application/json" id="ratings-data">{{ ratings_json|safe }}</script>
<script>
(function () {
  const raw = document.getElementById('papers-data').textContent;
  const papers = JSON.parse(raw);
  const list = document.getElementById('paper-list');
  const empty = document.getElementById('empty');
  const search = document.getElementById('search');
  const hideReadCheckbox = document.getElementById('hide-read');
  const metaCounts = document.getElementById('meta-counts');
  let activeTier = 'all';
  let searchTerm = '';

  // ---------- theme toggle ----------
  const THEME_KEY = 'srrss.theme';
  const themeBtn = document.getElementById('theme-toggle');
  const prefersDarkMQ = window.matchMedia('(prefers-color-scheme: dark)');

  function isDarkNow() {
    const t = document.documentElement.getAttribute('data-theme');
    if (t === 'dark') return true;
    if (t === 'light') return false;
    return prefersDarkMQ.matches;
  }
  function updateThemeIcon() {
    // Show the icon for the OPPOSITE mode — i.e. the action the click will take.
    const dark = isDarkNow();
    themeBtn.textContent = dark ? '☀' : '☾';
    themeBtn.setAttribute(
      'aria-label',
      dark ? 'Switch to light theme' : 'Switch to dark theme'
    );
  }
  themeBtn.addEventListener('click', function () {
    const next = isDarkNow() ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem(THEME_KEY, next); } catch (e) {}
    updateThemeIcon();
  });
  // If the OS theme changes while the user hasn't set a manual override,
  // keep the toggle icon in sync with the new auto state.
  if (prefersDarkMQ.addEventListener) {
    prefersDarkMQ.addEventListener('change', function () {
      if (!document.documentElement.hasAttribute('data-theme')) {
        updateThemeIcon();
      }
    });
  }
  updateThemeIcon();

  // ---------- admin mode ----------
  const ADMIN_HASH = '{{ admin_hash }}';
  const ADMIN_REPO = '{{ admin_repo }}';
  const ADMIN_KEY = 'srrss.admin';
  const PAT_KEY = 'srrss.github_pat';
  let isAdmin = false;

  async function sha256hex(str) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(function (b) { return b.toString(16).padStart(2, '0'); }).join('');
  }

  function setAdminMode(on) {
    isAdmin = on;
    document.body.classList.toggle('admin-mode', on);
    try {
      if (on) sessionStorage.setItem(ADMIN_KEY, 'true');
      else sessionStorage.removeItem(ADMIN_KEY);
    } catch (e) {}
  }

  async function promptAdmin() {
    if (!ADMIN_HASH) { showToast('Admin mode not configured'); return; }
    if (isAdmin) { setAdminMode(false); return; }
    const pw = prompt('Enter admin passphrase:');
    if (!pw) return;
    const h = await sha256hex(pw);
    if (h === ADMIN_HASH) {
      setAdminMode(true);
      showToast('Admin mode enabled');
      render();
    } else {
      showToast('Wrong passphrase');
    }
  }

  document.getElementById('admin-toggle').addEventListener('click', promptAdmin);
  if (ADMIN_HASH && sessionStorage.getItem(ADMIN_KEY) === 'true') setAdminMode(true);

  // ---------- toast ----------
  function showToast(msg, ms) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    clearTimeout(t._timer);
    t._timer = setTimeout(function () { t.classList.remove('show'); }, ms || 2500);
  }

  // ---------- ratings store (localStorage + cross-device merge) ----------
  const RATINGS_KEY = 'srrss.ratings';
  const QUEUE_KEY = 'srrss.queue';

  function getRatings() {
    try { return JSON.parse(localStorage.getItem(RATINGS_KEY)) || {}; } catch (e) { return {}; }
  }
  function saveRatings(r) {
    try { localStorage.setItem(RATINGS_KEY, JSON.stringify(r)); } catch (e) {}
  }
  function setRating(paperId, score, title) {
    const r = getRatings();
    if (score === 0) { delete r[paperId]; }
    else { r[paperId] = { score: score, rated_at: new Date().toISOString(), title: title || '' }; }
    saveRatings(r);
  }
  function getRating(paperId) {
    const r = getRatings();
    return r[paperId] ? r[paperId].score : 0;
  }
  function getQueue() {
    try { return JSON.parse(localStorage.getItem(QUEUE_KEY)) || []; } catch (e) { return []; }
  }
  function saveQueue(q) {
    try { localStorage.setItem(QUEUE_KEY, JSON.stringify(q)); } catch (e) {}
  }

  // Cross-device merge: bake server-side ratings into localStorage on load
  (function () {
    try {
      const serverRatings = JSON.parse(document.getElementById('ratings-data').textContent || '{}');
      const local = getRatings();
      let merged = false;
      for (const id in serverRatings) {
        if (!local[id] || (serverRatings[id].rated_at && local[id].rated_at && serverRatings[id].rated_at > local[id].rated_at)) {
          local[id] = serverRatings[id];
          merged = true;
        }
      }
      if (merged) saveRatings(local);
    } catch (e) {}
  })();

  // ---------- sync to GitHub ----------
  async function syncToGitHub() {
    if (!ADMIN_REPO) { showToast('Repo not configured'); return; }
    let pat = '';
    try { pat = localStorage.getItem(PAT_KEY) || ''; } catch (e) {}
    if (!pat) {
      pat = prompt('Enter a GitHub Personal Access Token\n(fine-grained, Contents read/write on this repo):');
      if (!pat) return;
      try { localStorage.setItem(PAT_KEY, pat); } catch (e) {}
    }
    const headers = { Authorization: 'Bearer ' + pat, 'Content-Type': 'application/json' };

    async function putFile(path, content, msg) {
      const url = 'https://api.github.com/repos/' + ADMIN_REPO + '/contents/' + path;
      // GET current SHA
      let sha = null;
      try {
        const res = await fetch(url, { headers: headers });
        if (res.ok) { sha = (await res.json()).sha; }
        else if (res.status === 401 || res.status === 403) {
          showToast('PAT rejected — clear it and retry');
          try { localStorage.removeItem(PAT_KEY); } catch (e) {}
          return false;
        }
      } catch (e) { showToast('Network error'); return false; }
      // PUT
      const body = { message: msg, content: btoa(unescape(encodeURIComponent(content))) };
      if (sha) body.sha = sha;
      try {
        const res = await fetch(url, { method: 'PUT', headers: headers, body: JSON.stringify(body) });
        if (res.status === 409) {
          // SHA stale — retry once
          const res2 = await fetch(url, { headers: headers });
          if (res2.ok) body.sha = (await res2.json()).sha;
          const res3 = await fetch(url, { method: 'PUT', headers: headers, body: JSON.stringify(body) });
          return res3.ok;
        }
        return res.ok;
      } catch (e) { return false; }
    }

    showToast('Syncing…');
    const ratingsPayload = JSON.stringify({ ratings: getRatings() }, null, 2);
    const queuePayload = JSON.stringify({ queue: getQueue() }, null, 2);
    const r1 = await putFile('data/ratings.json', ratingsPayload, 'Update paper ratings');
    const r2 = await putFile('data/queue.json', queuePayload, 'Update paper queue');
    showToast(r1 && r2 ? 'Synced ✓' : 'Sync failed — check PAT permissions');
  }

  document.getElementById('sync-btn').addEventListener('click', syncToGitHub);

  // ---------- add paper by DOI / arXiv ----------
  async function addPaper() {
    const input = document.getElementById('add-paper-input');
    const raw = (input.value || '').trim();
    if (!raw) return;
    const btn = document.getElementById('add-paper-btn');
    btn.disabled = true;
    btn.textContent = '…';

    try {
      let paper = null;
      // Detect arXiv ID
      const arxivMatch = raw.match(/(\d{4}\.\d{4,5})/);
      if (arxivMatch) {
        paper = await fetchArxiv(arxivMatch[1]);
      } else {
        // Try as DOI (strip URL prefixes)
        const doi = raw.replace(/^https?:\/\/(dx\.)?doi\.org\//i, '').trim();
        if (doi) paper = await fetchCrossRef(doi);
      }
      if (!paper) { showToast('Could not fetch paper metadata'); return; }
      // Add to queue
      const q = getQueue();
      if (q.some(function (p) { return p.id === paper.id; })) {
        showToast('Paper already in queue');
        return;
      }
      q.push(paper);
      saveQueue(q);
      input.value = '';
      showToast('Added: ' + paper.title.slice(0, 60) + (paper.title.length > 60 ? '…' : ''));
    } catch (e) {
      showToast('Error fetching metadata');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Add';
    }
  }

  async function fetchCrossRef(doi) {
    const res = await fetch('https://api.crossref.org/works/' + encodeURIComponent(doi));
    if (!res.ok) return null;
    const data = (await res.json()).message;
    return {
      id: 'doi:' + doi.toLowerCase(),
      title: (data.title || [''])[0],
      abstract: (data.abstract || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim(),
      authors: (data.author || []).map(function (a) { return (a.given || '') + ' ' + (a.family || ''); }).filter(Boolean),
      url: 'https://doi.org/' + doi,
      journal: (data['container-title'] || [''])[0],
      doi: doi.toLowerCase(),
      added_at: new Date().toISOString()
    };
  }

  async function fetchArxiv(arxivId) {
    const res = await fetch('https://export.arxiv.org/api/query?id_list=' + arxivId);
    if (!res.ok) return null;
    const text = await res.text();
    const parser = new DOMParser();
    const xml = parser.parseFromString(text, 'text/xml');
    const entry = xml.querySelector('entry');
    if (!entry) return null;
    const title = (entry.querySelector('title') || {}).textContent || '';
    const summary = (entry.querySelector('summary') || {}).textContent || '';
    const authors = Array.from(entry.querySelectorAll('author name')).map(function (n) { return n.textContent; });
    return {
      id: 'arxiv:' + arxivId,
      title: title.replace(/\s+/g, ' ').trim(),
      abstract: summary.replace(/\s+/g, ' ').trim(),
      authors: authors,
      url: 'https://arxiv.org/abs/' + arxivId,
      journal: 'arXiv',
      arxiv_id: arxivId,
      added_at: new Date().toISOString()
    };
  }

  document.getElementById('add-paper-btn').addEventListener('click', addPaper);
  document.getElementById('add-paper-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') addPaper();
  });

  // ---------- read-state (localStorage) ----------
  const READ_KEY = 'srrss.readPapers';
  const HIDE_READ_KEY = 'srrss.hideRead';

  function getReadSet() {
    try {
      const stored = localStorage.getItem(READ_KEY);
      return new Set(stored ? JSON.parse(stored) : []);
    } catch (e) {
      return new Set();
    }
  }
  function saveReadSet(set) {
    try { localStorage.setItem(READ_KEY, JSON.stringify(Array.from(set))); }
    catch (e) { /* quota or disabled */ }
  }
  function isRead(id) { return readSet.has(id); }
  function toggleRead(id) {
    if (readSet.has(id)) readSet.delete(id);
    else readSet.add(id);
    saveReadSet(readSet);
  }
  // Garbage-collect localStorage entries whose IDs aren't in the current feed.
  function gcReadSet(currentIds) {
    const next = new Set();
    readSet.forEach(function (id) { if (currentIds.has(id)) next.add(id); });
    if (next.size !== readSet.size) {
      readSet = next;
      saveReadSet(readSet);
    }
  }
  let readSet = getReadSet();
  const allIds = new Set(papers.map(function (p) { return p.id; }));
  gcReadSet(allIds);

  // restore hide-read preference
  const savedHideRead = localStorage.getItem(HIDE_READ_KEY) === 'true';
  hideReadCheckbox.checked = savedHideRead;
  let hideRead = savedHideRead;

  // ---------- helpers ----------
  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }
  function formatAuthors(authors) {
    if (!authors || !authors.length) return '';
    if (authors.length <= 3) return authors.join(', ');
    return authors.slice(0, 3).join(', ') + ' et al.';
  }

  // Classify a paper by journal string into one of three source types.
  function sourceType(journal) {
    if (!journal) return 'journal';
    if (journal.indexOf('bioRxiv') === 0) return 'biorxiv';
    if (journal.indexOf('arXiv') === 0)   return 'arxiv';
    return 'journal';
  }
  // Label shown inside the source pill (shorter than the full journal name).
  function sourceLabel(journal) {
    const t = sourceType(journal);
    if (t === 'biorxiv') return journal.replace(/^bioRxiv\s*/, 'bioRxiv · ');
    if (t === 'arxiv')   return journal.replace(/^arXiv\s*/,   'arXiv · ');
    return journal;
  }
  // Icon prefix for the pill — visible marker in addition to colour, for
  // accessibility and quick scanning.
  function sourceIcon(t) {
    if (t === 'biorxiv') return '\u{1F9EC}'; // DNA
    if (t === 'arxiv')   return '\u26A1';    // lightning bolt
    return '\u{1F4D6}';                      // open book
  }

  // ---------- counts shown in header + tier buttons ----------
  function recomputeCounts() {
    const total = papers.length;
    const unreadTotal = papers.filter(function (p) { return !isRead(p.id); }).length;
    const tierTotals = { high: 0, medium: 0, low: 0 };
    const tierUnread = { high: 0, medium: 0, low: 0 };
    papers.forEach(function (p) {
      if (tierTotals[p.tier] !== undefined) {
        tierTotals[p.tier] += 1;
        if (!isRead(p.id)) tierUnread[p.tier] += 1;
      }
    });
    metaCounts.textContent = total + ' papers (' + unreadTotal + ' unread)';
    function labelFor(t) {
      return t === 'all' ? 'All'
        : t === 'high' ? 'Must-read'
        : t === 'medium' ? 'Worth scanning'
        : 'On the radar';
    }
    function unreadFor(t) {
      return t === 'all' ? unreadTotal : tierUnread[t];
    }
    document.querySelectorAll('.tier-btn').forEach(function (btn) {
      const t = btn.dataset.tier;
      btn.textContent = labelFor(t) + ' (' + unreadFor(t) + ')';
    });
    // Mirror the same counts into the mobile dropdown options.
    document.querySelectorAll('#tier-select option').forEach(function (opt) {
      const t = opt.value;
      opt.textContent = labelFor(t) + ' (' + unreadFor(t) + ')';
    });
  }

  // ---------- render ----------
  function render() {
    const term = searchTerm.toLowerCase();
    const filtered = papers.filter(function (p) {
      if (activeTier !== 'all' && p.tier !== activeTier) return false;
      if (hideRead && isRead(p.id)) return false;
      if (!term) return true;
      const hay = (
        (p.title || '') + ' ' +
        (p.abstract || '') + ' ' +
        (p.journal || '') + ' ' +
        (p.authors || []).join(' ')
      ).toLowerCase();
      return hay.indexOf(term) !== -1;
    });

    if (!filtered.length) {
      list.innerHTML = '';
      empty.style.display = 'block';
      return;
    }
    empty.style.display = 'none';

    const html = filtered.map(function (p) {
      // Matched keywords (highlighted) + auto-extracted keywords (muted)
      var matchedSet = {};
      (p.matched_keywords || []).forEach(function (k) { matchedSet[k.toLowerCase()] = true; });
      const matchedChips = (p.matched_keywords || [])
        .map(function (k) { return '<span class="chip matched">' + escapeHtml(k) + '</span>'; })
        .join('');
      const autoChips = (p.auto_keywords || [])
        .map(function (k) { return '<span class="chip">' + escapeHtml(k) + '</span>'; })
        .join('');
      const chips = matchedChips + autoChips;
      const authorLine = formatAuthors(p.authors);
      const srcType = sourceType(p.journal || '');
      const sourcePillHtml = p.journal
        ? '<span class="source-pill source-' + srcType + '"><span class="src-icon">' + sourceIcon(srcType) + '</span>' + escapeHtml(sourceLabel(p.journal)) + '</span>'
        : '';
      const publishedLine = p.published ? new Date(p.published).toLocaleDateString() : '';
      const idAttr = escapeHtml(p.id);
      const readClass = isRead(p.id) ? ' read' : '';
      const readLabel = isRead(p.id) ? '✓ Read' : '↺ Mark read';
      const topYear = p.top_match_added_year ? ' &middot; top match added ' + p.top_match_added_year : '';
      const cosLine = (typeof p.max_cosine_weighted === 'number')
        ? ' &middot; weighted cosine ' + p.max_cosine_weighted.toFixed(3)
        : '';
      const llmLine = (typeof p.llm_score === 'number')
        ? ' &middot; LLM ' + p.llm_score.toFixed(0) + ' (stage1 ' + (p.stage1_score != null ? p.stage1_score.toFixed(0) : '?') + ')'
        : '';
      const sourceWeightLine = (typeof p.source_weight === 'number' && p.source_weight < 1.0 && typeof p.raw_final_score === 'number')
        ? ' &middot; source×' + p.source_weight.toFixed(2) + ' (raw ' + p.raw_final_score.toFixed(0) + ')'
        : '';
      return ''
        + '<article class="paper source-' + srcType + readClass + '" data-id="' + idAttr + '">'
        +   '<div class="paper-head">'
        +     '<h2 class="paper-title"><a href="' + escapeHtml(p.url) + '" target="_blank" rel="noopener">' + escapeHtml(p.title) + '</a></h2>'
        +     '<div class="paper-actions">'
        +       '<button class="read-toggle" data-action="toggle-read">' + readLabel + '</button>'
        +       (function () {
                  var r = getRating(p.id);
                  var s = '';
                  for (var i = 1; i <= 5; i++) s += '<button class="star' + (i <= r ? ' active' : '') + '" data-star="' + i + '">★</button>';
                  return '<span class="star-rating admin-only">' + s + '</span>';
                })()
        +       '<span class="tier-badge ' + p.tier + '">' + p.final_score.toFixed(0) + '</span>'
        +     '</div>'
        +   '</div>'
        +   '<div class="paper-meta">'
        +     sourcePillHtml
        +     (authorLine ? '<span class="dot">&middot;</span><span>' + escapeHtml(authorLine) + '</span>' : '')
        +     (publishedLine ? '<span class="dot">&middot;</span><span>' + publishedLine + '</span>' : '')
        +   '</div>'
        +   (p.abstract ? '<div class="paper-abstract">' + escapeHtml(p.abstract) + '</div>' : '')
        +   (chips ? '<div class="chips">' + chips + '</div>' : '')
        +   '<div class="score-detail">embedding ' + p.embedding_score.toFixed(0) + ' &middot; keywords ' + p.keyword_score.toFixed(0) + cosLine + llmLine + sourceWeightLine + topYear + '</div>'
        + '</article>';
    }).join('');
    list.innerHTML = html;

    // enable abstract expand on click
    list.querySelectorAll('.paper-abstract').forEach(function (el) {
      el.addEventListener('click', function () { el.classList.toggle('expanded'); });
    });

    // wire read-toggle buttons
    list.querySelectorAll('[data-action="toggle-read"]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        const card = btn.closest('.paper');
        const id = card.getAttribute('data-id');
        toggleRead(id);
        const nowRead = isRead(id);
        card.classList.toggle('read', nowRead);
        btn.textContent = nowRead ? '✓ Read' : '↺ Mark read';
        recomputeCounts();
        if (hideRead && nowRead) {
          // remove from view immediately
          card.style.display = 'none';
        }
      });
    });

    // wire star-rating buttons (admin mode)
    list.querySelectorAll('.star[data-star]').forEach(function (star) {
      star.addEventListener('click', function (e) {
        e.stopPropagation();
        const card = star.closest('.paper');
        const id = card.getAttribute('data-id');
        const val = parseInt(star.getAttribute('data-star'), 10);
        const current = getRating(id);
        const newVal = (val === current) ? 0 : val; // click same star to clear
        const title = (card.querySelector('.paper-title a') || {}).textContent || '';
        setRating(id, newVal, title);
        // update stars visually
        card.querySelectorAll('.star').forEach(function (s) {
          s.classList.toggle('active', parseInt(s.getAttribute('data-star'), 10) <= newVal);
        });
      });
    });
  }

  const tierSelect = document.getElementById('tier-select');

  function setActiveTier(t) {
    activeTier = t;
    document.querySelectorAll('.tier-btn').forEach(function (b) {
      b.classList.toggle('active', b.dataset.tier === t);
    });
    if (tierSelect && tierSelect.value !== t) tierSelect.value = t;
    render();
  }

  document.querySelectorAll('.tier-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      setActiveTier(btn.dataset.tier);
    });
  });
  if (tierSelect) {
    tierSelect.addEventListener('change', function (e) {
      setActiveTier(e.target.value);
    });
  }

  hideReadCheckbox.addEventListener('change', function (e) {
    hideRead = e.target.checked;
    localStorage.setItem(HIDE_READ_KEY, hideRead ? 'true' : 'false');
    render();
  });

  let searchTimer = null;
  search.addEventListener('input', function (e) {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function () {
      searchTerm = e.target.value;
      render();
    }, 120);
  });

  recomputeCounts();
  render();
})();
</script>
</body>
</html>
